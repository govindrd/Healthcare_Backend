            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Smith\",\n  \"email\": \"jane@example.com\",\n  \"phone\": \"1234567890\",\n  \"date_of_birth\": \"1990-01-01\",\n  \"gender\": \"F\",\n  \"blood_group\": \"O+\",\n  \"address\": \"123 Main St\",\n  \"city\": \"Mumbai\",\n  \"state\": \"Maharashtra\",\n  \"zip_code\": \"400001\",\n  \"medical_history\": \"None\",\n  \"allergies\": \"Pollen\",\n  \"emergency_contact\": \"John Doe\",\n  \"emergency_contact_phone\": \"0987654321\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/patients/",
              "host": ["{{base_url}}"],
              "path": ["api", "patients"]
            }
          }
        },
        {
          "name": "GET /api/patients/",
          "request": {
            "method": "GET",
