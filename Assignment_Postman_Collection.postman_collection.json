            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Smith Updated\",\n  \"email\": \"jane@example.com\",\n  \"phone\": \"1234567890\",\n  \"date_of_birth\": \"1990-01-01\",\n  \"gender\": \"F\",\n  \"blood_group\": \"O+\",\n  \"address\": \"456 Elm St\",\n  \"city\": \"Pune\",\n  \"state\": \"Maharashtra\",\n  \"zip_code\": \"411001\",\n  \"medical_history\": \"Updated history\",\n  \"allergies\": \"Pollen\",\n  \"emergency_contact\": \"John Doe\",\n  \"emergency_contact_phone\": \"0987654321\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/patients/1/",
              "host": ["{{base_url}}"],
              "path": ["api", "patients", "1"]
            }
          }
        },
        {
          "name": "DELETE /api/patients/<id>/",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/patients/1/",
              "host": ["{{base_url}}"],
              "path": ["api", "patients", "1"]
            }
          }
        }
