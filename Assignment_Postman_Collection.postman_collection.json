              "host": ["{{base_url}}"],
              "path": ["api", "patients", "1"]
            }
          }
        },
        {
          "name": "PUT /api/patients/<id>/",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
